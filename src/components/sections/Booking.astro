---
interface Props {
  ui: {
    heading_en: string;
    heading_ro: string;
    name_placeholder_en: string;
    name_placeholder_ro: string;
    phone_placeholder_en: string;
    phone_placeholder_ro: string;
    button_en: string;
    button_ro: string;
  };
}

const { ui } = Astro.props;
---

<section class="bg-gradient-to-br from-primary to-primary-dark py-12 md:py-20 px-4 md:px-8 text-center" id="booking">
  <div class="max-w-[1600px] mx-auto">
    <h2 class="font-display text-[1.8rem] md:text-[2.4rem] text-white mb-4" data-en={ui.heading_en} data-ro={ui.heading_ro}>{ui.heading_en}</h2>
    <div class="flex flex-col md:flex-row gap-4 justify-center flex-wrap">
      <input type="text" placeholder={ui.name_placeholder_en} data-en-placeholder={ui.name_placeholder_en} data-ro-placeholder={ui.name_placeholder_ro} class="px-6 py-[0.85rem] rounded-full border-0 outline-none text-[0.95rem] bg-white/95 text-text-dark w-full md:min-w-[180px] md:w-auto" />
      <input type="tel" placeholder={ui.phone_placeholder_en} data-en-placeholder={ui.phone_placeholder_en} data-ro-placeholder={ui.phone_placeholder_ro} class="px-6 py-[0.85rem] rounded-full border-0 outline-none text-[0.95rem] bg-white/95 text-text-dark w-full md:min-w-[180px] md:w-auto" />
      <button class="bg-white text-primary font-bold text-[0.95rem] px-8 py-[0.85rem] rounded-full border-0 cursor-pointer" data-en={ui.button_en} data-ro={ui.button_ro}>{ui.button_en}</button>
    </div>
  </div>
</section>
