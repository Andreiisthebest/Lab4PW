---
interface Props {
  contact: {
    address: string;
    phone: string;
    email: string;
    hours_en: string;
    hours_ro: string;
    map_embed_url: string;
  };
  ui: {
    heading_en: string;
    heading_ro: string;
  };
}

const { contact, ui } = Astro.props;
---

<section class="bg-bg-light py-12 md:py-20 px-4 md:px-8" id="contact">
  <div class="max-w-[1600px] mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-start">
      <div>
        <h2 class="font-display text-[1.6rem] md:text-[2rem] text-text-dark mb-6" data-en={ui.heading_en} data-ro={ui.heading_ro} set:html={ui.heading_en}></h2>
        <p class="text-text-light text-[0.9rem] mb-3" data-en={contact.address} data-ro={contact.address}>{contact.address}</p>
        <p class="text-text-light text-[0.9rem] mb-3">{contact.phone}</p>
        <p class="text-text-light text-[0.9rem] mb-3">{contact.email}</p>
        <p class="text-text-light text-[0.9rem]" data-en={contact.hours_en} data-ro={contact.hours_ro}>{contact.hours_en}</p>
      </div>
      <div class="w-full aspect-[4/3] rounded-[16px] overflow-hidden shadow-card-lg">
        <iframe src={contact.map_embed_url} width="100%" height="100%" style="border:0;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="SVET MEDICAL location" class="w-full h-full block"></iframe>
      </div>
    </div>
  </div>
</section>
