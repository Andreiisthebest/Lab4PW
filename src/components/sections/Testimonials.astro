---
interface TestimonialItem {
  quote_en: string;
  quote_ro: string;
  author: string;
}

interface Props {
  testimonials: TestimonialItem[];
}

const { testimonials } = Astro.props;
---

<section class="bg-white py-12 md:py-20 px-4 md:px-8">
  <div class="max-w-[1600px] mx-auto">
    <div class="text-center mb-14">
      <h2 class="font-display text-[1.7rem] md:text-[2.2rem] text-text-dark" data-en="What Our Clients Say" data-ro="Ce Spun Clientii Nostri">What Our Clients Say</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {testimonials.map((item) => (
        <div class="bg-bg-light p-8 rounded-[20px] shadow-card-lift">
          <p class="text-text-light mb-4" data-en={item.quote_en} data-ro={item.quote_ro}>{item.quote_en}</p>
          <h4 class="text-text-dark font-semibold" data-en={`- ${item.author}`} data-ro={`- ${item.author}`}>{`- ${item.author}`}</h4>
        </div>
      ))}
    </div>
  </div>
</section>
