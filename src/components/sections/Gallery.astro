            <span class="text-white text-[0.8rem] font-semibold tracking-[0.08em] uppercase" data-en="Watch Video" data-ro="Vezi Video">Watch Video</span>
        </div>
      </div>
      <div class="relative bg-[#111] rounded-[12px] overflow-hidden aspect-video cursor-pointer group" onclick="openVideoLightbox('/images/video5.mp4')">
