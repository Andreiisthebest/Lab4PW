<section class="bg-white py-12 md:py-20 px-4 md:px-8" id="gallery">
  <div class="max-w-[1600px] mx-auto">
    <div class="text-center mb-14">
      <span class="text-[0.8rem] tracking-[0.22em] uppercase text-primary font-semibold block mb-3" data-en="Our Work" data-ro="Munca Noastra">Our Work</span>
      <h2 class="font-display text-[1.7rem] md:text-[2.2rem] text-text-dark mb-4" data-en="Gallery" data-ro="Galerie">Gallery</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="relative bg-[#111] rounded-[12px] overflow-hidden aspect-video cursor-pointer group" onclick="openVideoLightbox('/images/video4.mp4')">
        <video src="/images/video4.mp4" muted preload="metadata" class="w-full h-full object-cover block pointer-events-none"></video>
      </div>
      <div class="relative bg-[#111] rounded-[12px] overflow-hidden aspect-video cursor-pointer group" onclick="openVideoLightbox('/images/video5.mp4')">
        <video src="/images/video5.mp4" muted preload="metadata" class="w-full h-full object-cover block pointer-events-none"></video>
      </div>
    </div>
  </div>
</section>
