---
import '../styles/reset.css';
import '../styles/theme.css';
import '../styles/legacy-inline.css';

interface Props {
  title?: string;
}

const { title = 'SVET MEDICAL - Beauty Salon' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <!-- Netlify Identity Widget for CMS invites -->
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js" is:inline></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap"
      rel="stylesheet"
    />

    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              primary: '#c9a96e',
              'primary-dark': '#a07840',
              secondary: '#f3e9d2',
              'text-dark': '#2c2c2c',
              'text-light': '#7a7a7a',
              'bg-light': '#fdf8f2'
            },
            fontFamily: {
              sans: ['Inter', 'sans-serif'],
              display: ['"Playfair Display"', 'serif']
            },
            boxShadow: {
              card: '0 4px 6px rgba(0,0,0,0.08)',
              'card-lg': '0 10px 30px rgba(0,0,0,0.12)'
            },
            borderRadius: {
              '4xl': '2rem'
            },
            maxWidth: {
              container: '1600px'
            }
          }
        }
      };
    </script>
  </head>
  <body>
    <slot />
    
    <!-- Netlify Identity redirect script -->
    <script is:inline>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", user => {
          if (!user) {
            window.netlifyIdentity.on("login", () => {
              document.location.href = "/admin/";
            });
          }
        });
      }
    </script>
  </body>
</html>
